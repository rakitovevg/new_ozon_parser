# Database
DATABASE_URL=sqlite+aiosqlite:///./data/ozon.db

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Search URL: full URL = URL1 + brand.name + "-" + brand.code + URL2 + model
SEARCH_URL1=
SEARCH_URL2=

# Selenium / Chrome (optional)
CHROME_VERSION_MAIN=145

# Selectors (Ozon listing page)
SELECTOR_TILE_ROOT=.tile-root
SELECTOR_PRICE=.c35_3_13-a6
SELECTOR_NAME_LINK=.ki4_24
SELECTOR_WAIT_TIMEOUT=30
SELECTOR_MAX_CARDS=100

# ScrapingBee (recommended for server: bypass antibot, returns rendered HTML)
# https://scrapingbee.com/
SCRAPINGBEE_API_KEY=
SCRAPINGBEE_RENDER_JS=true
SCRAPINGBEE_STEALTH_PROXY=true
SCRAPINGBEE_COUNTRY_CODE=ru
SCRAPINGBEE_BLOCK_RESOURCES=false
SCRAPINGBEE_WAIT=7000

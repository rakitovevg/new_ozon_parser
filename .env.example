# Database
DATABASE_URL=sqlite+aiosqlite:///./data/ozon.db

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Legacy fallback URL constructor for old tasks (optional)
# Full URL = SEARCH_URL1 + brand.name + "-" + brand.code + SEARCH_URL2 + model
SEARCH_URL1=
SEARCH_URL2=

# Selectors (Ozon listing page). Цена: сначала SELECTOR_PRICE, иначе авто-поиск (₽, tsHeadline…)
SELECTOR_TILE_ROOT=.tile-root
SELECTOR_PRICE=.c35_3_15-a0 span.tsHeadline500Medium
SELECTOR_NAME_LINK=.ki4_24
SELECTOR_WAIT_TIMEOUT=30
SELECTOR_MAX_CARDS=100

# Remote Chrome over CDP (recommended runtime mode)
USE_REMOTE_CHROME=false
# Optional static websocket URL (may change after Chrome restart)
REMOTE_CHROME_WS=
# Stable DevTools HTTP endpoint used for auto-discovery:
# app reads /json/version and takes webSocketDebuggerUrl dynamically
REMOTE_CHROME_HTTP=http://127.0.0.1:9222

# Task timeout in seconds
TASK_HARD_TIMEOUT_SECONDS=600

# Public URL of the admin (e.g. https://parser.example.com) — canonical link in HTML; no trailing slash
PUBLIC_BASE_URL=
# Behind nginx: comma-separated Host values to trust for X-Forwarded-* headers, or * (default)
TRUSTED_PROXY_HOSTS=*

# External healthcheck (scripts/healthcheck_telegram.py + systemd timer, см. DEPLOY.md)
# HEALTHCHECK_URL=http://127.0.0.1:8000/
# HEALTHCHECK_STATE_FILE=/tmp/ozon_parser_health.json
# HEALTHCHECK_REPEAT_SEC=3600
# HEALTHCHECK_RECOVER_NOTIFY=true
